# PostgreSQL connection (matches the cinemind_ai_schema.sql tables: users, movies, chats, chat_messages)
DATABASE_URL=postgresql+asyncpg://cinemind_user:cinemind_pass@localhost:5432/cinemind_ai

# Anthropic API key, used to power the CineMind AI chat endpoint
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
