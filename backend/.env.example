# Application
APP_NAME=CineMind AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://cinemind:cinemind@localhost:5432/cinemind

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=movies

# OpenAI (optional — mock responses used when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Demo user for anonymous MVP chat (created on startup if missing)
DEMO_USER_EMAIL=demo@cinemind.local
